{
  "name": "aeva-ui",
  "version": "0.1.6",
  "description": "The light, bouncy, and effortlessly chill UI library for the next gen of web developers. Build fast, stay relaxed.",
  "type": "module",
  "sideEffects": false,
  "customElements": "custom-elements.json",
  "main": "./dist/aeva-ui.umd.cjs",
  "module": "./dist/aeva-ui.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/aeva-ui.bundle.js",
  "jsdelivr": "./dist/aeva-ui.bundle.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/aeva-ui.js",
      "require": "./dist/aeva-ui.umd.cjs",
      "default": "./dist/aeva-ui.bundle.js"
    },
    "./style.css": "./dist/style.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amrishodiq/aeva-ui.git"
  },
  "bugs": {
    "url": "https://github.com/amrishodiq/aeva-ui/issues"
  },
  "homepage": "https://github.com/amrishodiq/aeva-ui#readme",
  "files": [
    "dist",
    "custom-elements.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && vite build --mode bundle",
    "analyze": "custom-elements-manifest analyze",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "web-components",
    "lit",
    "design-system",
    "ui-library",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "lit": "^3.3.2",
    "prettier": "^3.8.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@lit-labs/context": "^0.5.1",
    "lit": "^3.3.2"
  }
}