{
    "name": "@aeva/ui",
    "version": "0.1.0",
    "description": "A modern design system library built with Lit web components for rapid web development",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/aeva-ui.umd.cjs",
    "module": "./dist/aeva-ui.js",
    "types": "./dist/index.d.ts",
    "unpkg": "./dist/aeva-ui.umd.cjs",
    "jsdelivr": "./dist/aeva-ui.umd.cjs",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/aeva-ui.js",
            "require": "./dist/aeva-ui.umd.cjs"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/amrishodiq/aeva-ui.git"
    },
    "bugs": {
        "url": "https://github.com/amrishodiq/aeva-ui/issues"
    },
    "homepage": "https://github.com/amrishodiq/aeva-ui#readme",
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "keywords": [
        "web-components",
        "lit",
        "design-system",
        "ui-library",
        "typescript"
    ],
    "author": "",
    "license": "MIT",
    "peerDependencies": {
        "lit": "^3.3.2"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^8.53.0",
        "@typescript-eslint/parser": "^8.53.0",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "lit": "^3.3.2",
        "prettier": "^3.8.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.1"
    },
    "dependencies": {
        "@lit-labs/context": "^0.5.1"
    }
}